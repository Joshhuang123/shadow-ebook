# Keep structure but ignore contents
data/books/*.json
data/words/*.json
data/words/*.txt
data/grammar/*.json

# 家长数据 + PIN hash (sensitive, NEVER commit)
data/parent/*
!data/parent/.gitkeep

# Phase 3: SQLite DB (runtime state, regenerated on first startup)
data/shadow.db
data/shadow.db-shm
data/shadow.db-wal
data/.migration_marker
data/.parent_migrated
data/books.migrated-*/
data/parent.migrated-*/

# Round 1: Flask session 秘钥 (持久, 不入库) + 日志轮转产物
data/.secret
data/shadow.log
data/shadow.log.*

# Logs
*.log

